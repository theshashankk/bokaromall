# ==========================================
# Bokaro Mall Redesign - Complete .gitignore
# ==========================================

# 1. Dependencies & Package Managers
/node_modules
/.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store

# 2. Next.js & Build Outputs
/.next/
/out/
/build
/dist
/.turbo

# 3. Environment Variables & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env*.local

# 4. Logs & Debug Traces
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 5. Deployment Services
.vercel

# 6. IDEs & Code Editors
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# 7. OS Generated Unwanted Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# 8. TypeScript & Cache
*.tsbuildinfo
next-env.d.ts
